# --- Core Node ---
NODE_NAME=my-open-realms-node
NODE_PUBLIC_URL=http://localhost:8080
PORT=8080
MOTHUB_ADMIN_KEY=change-me-to-random-secret
SEED_NODES=
SYNC_INTERVAL_MS=60000
WORKER_MODE=leader

# --- Validator Integration (optional) ---
VALIDATOR_URL=http://pot-o-validator:8900
VALIDATOR_DEVICE_TYPE=mothub_node
VALIDATOR_AUTO_REGISTER=true
VALIDATOR_SYNC_PEERS=true
VALIDATOR_KEYPAIR_PATH=/keys/relayer.json

# --- Mining (optional, requires VALIDATOR_URL) ---
MINER_ENABLED=false
CHALLENGE_POLL_INTERVAL=15000

# --- AI Provider Keys ---
OPENROUTER_API_KEY=
HF_API_KEY=
GROQ_API_KEY=

# --- Advanced ---
BOOTSTRAP_URLS=http://bootstrap.tribewarez.com/peers
SOLANA_RPC_URL=http://solana-rpc:8899
